# =============================================
# LLM endpoint (OpenAI-compatible, used for chat completion)
# Copy this file to .env and fill in your own values.
# =============================================
LITELLM_API_KEY=your_api_key_here
LITELLM_BASE_URL=https://your-llm-endpoint.example.com/v1

# =============================================
# LLM model
# The "openai/" prefix marks this as an OpenAI-compatible endpoint.
# =============================================
DEFAULT_LLM_MODEL=openai/gpt-oss-20b

# ---------------------------------------------
# Alternative: run generation fully locally with Ollama.
# Ollama exposes an OpenAI-compatible endpoint at /v1, so no code changes
# are needed — just pull a model and uncomment the three lines below.
#   ollama pull llama3.1
# ---------------------------------------------
# LITELLM_BASE_URL=http://localhost:11434/v1
# LITELLM_API_KEY=ollama        # any non-empty string; Ollama ignores it
# DEFAULT_LLM_MODEL=llama3.1     # native Ollama tag (no "openai/" prefix)

# =============================================
# Embedding model (served locally by Ollama)
# Install Ollama, then run: ollama pull nomic-embed-text
# =============================================
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# =============================================
# Vector DB (ChromaDB — pure Python, no Docker)
# =============================================
CHROMA_PERSIST_DIR=./chroma_db

# =============================================
# Use this repo as a template for your own data
# (Defaults match the bundled UAV example; override these
#  when you replace data/raw/ with your own files.)
# =============================================
# RAG_DOMAIN=your topic in one phrase (used in the assistant's system prompt)
# COLLECTION_NAME=your_topic_slug
# SEED_QUESTIONS_FILE=./seed_questions.json   # optional, for skill_builder.py

# =============================================
# Chunking
# =============================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
